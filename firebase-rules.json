{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid || auth.token.isAdmin === true",
        ".write": "auth.uid === $uid && (
          (newData.hasChildren(['dailyWatchCount', 'lastWatchDate', 'weeklyEarned']) && 
           !newData.hasChild('balance') && 
           !newData.hasChild('totalEarned'))
          ||
          auth.token.isAdmin === true
        )",
        "balance": {
          ".write": "auth.token.isAdmin === true"
        },
        "totalEarned": {
          ".write": "auth.token.isAdmin === true"
        },
        "dailyWatchCount": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 30"
        },
        "lastWatchDate": {
          ".validate": "newData.isString()"
        },
        "weeklyEarned": {
          ".write": "$uid === auth.uid"
        },
        "dailyBonusStreak": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 7"
        },
        "$other": {
          ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean()"
        }
      }
    },
    "ad_sessions": {
      "$sessionId": {
        ".read": "auth.token.isAdmin === true",
        ".write": "auth.uid === newData.child('userId').val() && !data.exists()",
        "status": {
          ".validate": "newData.val() === 'pending' || newData.val() === 'verified'"
        }
      }
    },
    "withdraw_requests": {
      "$requestId": {
        ".read": "auth.token.isAdmin === true || data.child('userId').val() === auth.uid",
        ".write": "auth.token.isAdmin === true || (!data.exists() && newData.child('userId').val() === auth.uid)",
        "status": {
          ".validate": "newData.val() === 'pending' || newData.val() === 'approved' || newData.val() === 'rejected'"
        },
        "amount": {
          ".validate": "newData.isNumber() && newData.val() >= 1000"
        }
      }
    },
    "ad_impressions": {
      "$impressionId": {
        ".read": "auth.token.isAdmin === true",
        ".write": "auth.uid === newData.child('userId').val()"
      }
    },
    "adsgram_impressions": {
      "$impressionId": {
        ".read": "auth.token.isAdmin === true",
        ".write": "auth.uid === newData.child('userId').val()"
      }
    },
    "settings": {
      ".read": true,
      ".write": "auth.token.isAdmin === true"
    }
  }
}
