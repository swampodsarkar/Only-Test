{
  "rules": {
    "users": {
      "$uid": {
        ".read": true,
        ".write": "!newData.hasChild('balance') && !newData.hasChild('totalEarned') || data.exists()",
        "balance": {
          ".write": false
        },
        "totalEarned": {
          ".write": false
        },
        "dailyWatchCount": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 30"
        },
        "lastWatchDate": {
          ".validate": "newData.isString()"
        },
        "dailyBonusStreak": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 7"
        },
        "$other": {
          ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean()"
        }
      }
    },
    "ad_sessions": {
      "$sessionId": {
        ".read": true,
        ".write": "!data.exists()",
        "status": {
          ".validate": "newData.val() === 'pending'"
        }
      }
    },
    "withdraw_requests": {
      "$requestId": {
        ".read": true,
        ".write": "!data.exists()",
        "amount": {
          ".validate": "newData.isNumber() && newData.val() >= 1000"
        }
      }
    },
    "ad_impressions": {
      ".read": true,
      ".write": true
    },
    "adsgram_impressions": {
      ".read": true,
      ".write": true
    },
    "settings": {
      ".read": true,
      ".write": false
    }
  }
}
